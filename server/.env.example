# ---- Server configuration ----
PORT=4000
NODE_ENV=development

# ---- PostgreSQL ----
# Either set DATABASE_URL, or the individual PG* variables below.
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/fifa_wc2026
# PGHOST=localhost
# PGPORT=5432
# PGUSER=postgres
# PGPASSWORD=postgres
# PGDATABASE=fifa_wc2026

# Set to "true" only if your Postgres host requires SSL (most managed hosts do)
PGSSL=false

# ---- Admin access ----
# The single shared key the admin panel uses. CHANGE THIS in production.
ADMIN_KEY=wcd-admin-2026

# ---- CORS ----
# Comma separated list of allowed origins for the API. Use * for any (dev only).
CORS_ORIGIN=http://localhost:5173

# When the React build is copied into ../client/dist, the server will also
# serve it as static files. Set to false to run API only.
SERVE_CLIENT=false
